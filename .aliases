# Aliases
alias grep='nocorrect grep --color=auto'

alias sudopath='sudo env PATH=$PATH'

# shortened commands
alias l='ls'
alias la='ls -a'
alias v='vim'
alias vi='vim'

alias rezsh='source ~/.zshrc'

# git aliases
alias g='git'
alias ga='git add'
alias gp='git push'
alias gl='git log'
alias gs='git status'
alias gd='git diff'
alias gm='git commit -m'
alias gma='git commit -am'
alias gb='git branch'
alias gc='git checkout'
alias gra='git remote add'
alias grr='git remote rm'
alias gpu='git pull'
alias gcl='git clone'

if [[ -f ~/.aliases_local ]]
then
	source ~/.aliases_local
fi

# ack -> rg migration reminder
ack() { echo "Use rg instead of ack"; rg "$@"; }

alias colout='python ~/bin/colout/colout.py'

#color aliases
alias rainbow='colout "^.*$" rainbow'
alias Rainbow='colout "^.*$" Rainbow'

# Claude Code in tmux
cc() {
  local name="${1:-claude-$(date +%H%M%S)}"
  shift 2>/dev/null
  tmux new-session -d -s "$name" "claude $*; zsh" && tmux attach -t "$name"
}

# Claude Code with specific model in tmux
cch() { cc "haiku-$(date +%H%M%S)" --model haiku "$@"; }
ccs() { cc "sonnet-$(date +%H%M%S)" --model sonnet "$@"; }
cco() { cc "opus-$(date +%H%M%S)" --model opus "$@"; }

# Codex in tmux
cx() {
  local name="${1:-codex-$(date +%H%M%S)}"
  shift 2>/dev/null
  tmux new-session -d -s "$name" "codex $*; zsh" && tmux attach -t "$name"
}
