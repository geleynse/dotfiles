# Ignore everything by default (whitelist approach)
*

# Core dotfiles
!.gitignore
!.gitconfig
!.gitmodules
!.aliases
!.zshrc
!.zsh_modules
!.zsh_modules/**
!.tmux.conf
!.vimrc
!.vim
!.vim/**
.vim/.netrwhist

# Never commit _local variants (machine-specific)
*_local

# Selective .config dirs
!.config
!.config/git
!.config/git/**
!.config/restic
!.config/restic/**
# Ignore restic credentials
.config/restic/env
.config/restic/password

# Scripts and utilities
!bin
!bin/**
!scripts
!scripts/**
# Ignore compiled/cached files and large binaries
bin/__pycache__
scripts/__pycache__
bin/*.AppImage
bin/*.appimage
bin/orca-slicer

# Repo files
!LICENSE
!README.md
